# URL HTTPS pública donde quedará publicada la app.
APP_PUBLIC_URL=https://appservicios-mn6i.onrender.com

# Genera uno real y guárdalo solo como secreto del hosting o en .env local.
JWT_KEY=REEMPLAZAR_CON_SECRETO_LARGO

# Mercado Pago: usar credenciales productivas de tu cuenta.
MERCADOPAGO_ACCESS_TOKEN=APP_USR_REEMPLAZAR
MERCADOPAGO_PUBLIC_KEY=APP_USR_REEMPLAZAR
MERCADOPAGO_USE_SANDBOX=false

# Web Push / VAPID.
VAPID_PUBLIC_KEY=REEMPLAZAR_CON_PUBLIC_KEY
VAPID_PRIVATE_KEY=REEMPLAZAR_CON_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@appservicios.com

# Super Admin productivo: usar valores reales solo en Render o .env local.
SuperAdmin__Email=superadmin@appservicios.com
SuperAdmin__Password=REEMPLAZAR_CON_PASSWORD_LARGO
SuperAdmin__Name=Super Admin AppServicios
SuperAdmin__Phone=0000000000
SuperAdmin__Dni=00000000
Security__SuperAdminFailedIpBlockThreshold=32
Security__RecoveryKey=REEMPLAZAR_CON_RECOVERY_KEY_LARGA

# Planes comerciales.
Planes__Fundadores__MaxCupos=100
Planes__Fundadores__AltaArs=2500
Planes__Fundadores__MensualidadArs=2500
Planes__Fundadores__MesesPromocion=3
Planes__PagoProtegido__ComisionPorcentaje=2

# IA real con OpenAI. Guardar la API key solo como secreto del hosting o .env local.
OPENAI_API_KEY=REEMPLAZAR_CON_OPENAI_API_KEY
OpenAI__Model=gpt-4.1-mini

# Telefonica Open Gateway / CAMARA sandbox.
OPEN_GATEWAY_AUTH_URL=https://REEMPLAZAR_TOKEN_URL
OPEN_GATEWAY_CLIENT_ID=REEMPLAZAR_CLIENT_ID
OPEN_GATEWAY_CLIENT_SECRET=REEMPLAZAR_CLIENT_SECRET
OPEN_GATEWAY_SCOPE=REEMPLAZAR_SCOPE_SI_APLICA
OPEN_GATEWAY_AUDIENCE=REEMPLAZAR_AUDIENCE_SI_APLICA
OPEN_GATEWAY_SIM_SWAP_URL=https://REEMPLAZAR_SIM_SWAP_URL
OPEN_GATEWAY_DEVICE_LOCATION_URL=https://REEMPLAZAR_DEVICE_LOCATION_URL
OPEN_GATEWAY_AUTH_TIMEOUT_SECONDS=5.0
OPEN_GATEWAY_TOKEN_MARGIN_SECONDS=60
OPEN_GATEWAY_LOCATION_RADIUS_METERS=50000

# Sandbox de seguridad antifraude. No subir reportes generados.
SECURITY_REPORTS_DIR=reportes_antifraude
SECURITY_TEST_NAME=Usuario Sandbox
SECURITY_TEST_PHONE=+5492611234567
IQS_API_KEY=REEMPLAZAR_IQS_API_KEY
IQS_PHONE_VALIDATION_URL=https://REEMPLAZAR_IQS_PHONE_VALIDATION_URL
MAXMIND_ACCOUNT_ID=REEMPLAZAR_MAXMIND_ACCOUNT_ID
MAXMIND_LICENSE_KEY=REEMPLAZAR_MAXMIND_LICENSE_KEY
MAXMIND_MINFRAUD_URL=https://REEMPLAZAR_MAXMIND_MINFRAUD_URL
NOMINATIM_SEARCH_URL=https://nominatim.openstreetmap.org/search
